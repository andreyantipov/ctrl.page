{
  "name": "@ctrl/desktop",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "dependencies": {
    "electrobun": "latest",
    "@ctrl/shared": "workspace:*",
    "@ctrl/ui": "workspace:*",
    "solid-js": "latest"
  },
  "devDependencies": {
    "@dschz/bun-plugin-solid": "^1.0.4",
    "@types/bun": "latest"
  },
  "scripts": {
    "prebundle": "bun run build-view.ts",
    "build": "bun install && bun run prebundle && electrobun build",
    "start": "bun run build && electrobun dev",
    "dev": "bun run build && electrobun dev",
    "check": "tsgo --noEmit 2>&1 | (! grep -v 'node_modules/' | grep 'error TS')"
  }
}
